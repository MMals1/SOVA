{
  "name": "sova-wallet-extension",
  "version": "2.0.0",
  "private": true,
  "description": "Test tooling for Wolf Wallet browser extension",
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:install-browsers": "playwright install chromium",
    "site:dev": "node site/server.mjs",
    "site:open": "open http://127.0.0.1:5173",
    "build:extension": "npm run build && cd extension && zip -r ../wolf-wallet-extension.zip . -x '*.bundle.js.map' && cp ../wolf-wallet-extension.zip ../site/assets/",
    "build:verify": "node scripts/verify-build.js",
    "package": "npm run build && npm run build:verify && cd extension && zip -r ../sova-wallet.zip . -x '*.bundle.js.map' '*.ts' '*.d.ts'",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.53.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --max-warnings 400",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
